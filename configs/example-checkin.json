{
  "scenarioId": "example-checkin",
  "scenarioName": "示範簽到場景",
  "uiTheme": { "primary": "#1e8050", "background": "#f5f6f8" },
  "trigger": "auto",
  "concurrency": "multi-face",
  "dedupWindowMs": 30000,
  "consentNotice": {
    "enabled": true,
    "message": "本系統將擷取您的人臉特徵以進行簽到，資料留在本機。是否同意？",
    "requireExplicitConsent": true
  },
  "extraFields": [
    {
      "key": "companions",
      "label": "陪同家屬",
      "type": "multi-text",
      "placeholder": "輸入家屬姓名",
      "scope": "event",
      "collectOn": "every",
      "required": false
    }
  ],
  "tts": {
    "enabled": true,
    "templateNamed": "{name} {greeting}"
  }
}
